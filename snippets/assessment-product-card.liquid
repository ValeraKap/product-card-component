{%- doc -%}
  Renders sale badge, variant swatches, hover secondary image, brand, title, and pricing.

  @param {object} product - Product object
  @param {object} [block] - Optional block object
{%- enddoc -%}

{% liquid
  assign product = product | default: closest.product

  if block and block.id
    assign card_id = 'assessment-product-card-' | append: block.id | append: '-' | append: product.id
  else
    assign card_id = 'assessment-product-card-' | append: product.id
  endif
%}

{% if product == blank %}
  <article
    class="assessment-product-card relative isolate z-0 mb-4 flex w-[calc(100%-6px)] min-w-0 max-w-[315px] flex-col items-start gap-[15px] p-0 text-[#111111] md:w-full"
    aria-hidden="true"
  >
    <div class="assessment-image-panel relative box-border h-[270px] w-full overflow-hidden rounded-[10px] border bg-white md:h-[340px]">
      <div class="assessment-media-frame relative block h-full w-full">
        {{ 'product-apparel-1' | placeholder_svg_tag: 'absolute inset-0 h-full w-full object-contain p-[8px]' }}
      </div>
    </div>
    <div class="flex w-full max-w-[246px] min-w-0 flex-col items-start gap-2">
      <p class="text-[14px] font-normal leading-[16px] text-[#111111]">
        {{ shop.name }}
      </p>
      <p class="m-0 text-[16px] font-medium leading-[18px] text-[#0A4874]">
        {{ 'content.product_card_placeholder' | t }}
      </p>
    </div>
  </article>
{% else %}
  {% liquid
    assign selected_variant = product.selected_or_first_available_variant
    if selected_variant == blank
      assign selected_variant = product.variants.first
    endif

    assign product_images = product.media | where: 'media_type', 'image'
    assign fallback_image = product_images.first

    assign selected_primary = selected_variant.featured_media
    if selected_primary == blank or selected_primary.media_type != 'image'
      assign selected_primary = fallback_image
    endif

    assign selected_secondary = blank
    if product_images.size > 1 and selected_primary != blank
      for media in product_images
        if media.position > selected_primary.position
          assign selected_secondary = media
          break
        endif
      endfor
    endif
    if selected_secondary == blank and product_images.size > 1
      for media in product_images
        if selected_primary != blank and media.id == selected_primary.id
          continue
        endif
        assign selected_secondary = media
        break
      endfor
    endif

    assign secondary_fallback = selected_secondary
    if secondary_fallback == blank
      assign secondary_fallback = selected_primary
    endif
    if secondary_fallback == blank
      assign secondary_fallback = fallback_image
    endif

    assign image_alt_fallback = product.title | strip
    if image_alt_fallback == blank
      assign image_alt_fallback = 'content.product_image' | t
    endif
    assign card_image_sizes = '(max-width: 767px) 50vw, (max-width: 1023px) 33vw, 25vw'

    assign selected_on_sale = false
    if selected_variant.compare_at_price > selected_variant.price
      assign selected_on_sale = true
    endif

    assign manual_sale_badge = false
    if product.metafields.custom.sale_badge_enabled != blank
      assign manual_sale_badge = product.metafields.custom.sale_badge_enabled.value
    endif

    assign sale_badge_mode = 'default'
    if product.metafields.custom.sale_badge_mode != blank
      assign sale_badge_mode = product.metafields.custom.sale_badge_mode.value | downcase | strip
    endif
    unless sale_badge_mode == 'force_show' or sale_badge_mode == 'force_hide'
      assign sale_badge_mode = 'default'
    endunless

    assign sale_badge_visible = selected_on_sale
    if sale_badge_mode == 'force_show'
      assign sale_badge_visible = true
    elsif sale_badge_mode == 'force_hide'
      assign sale_badge_visible = false
    elsif manual_sale_badge
      assign sale_badge_visible = true
    endif

    assign sale_badge_text = 'content.product_badge_sale' | t
    if product.metafields.custom.sale_badge_text != blank
      assign sale_badge_text = product.metafields.custom.sale_badge_text.value | strip
      if sale_badge_text == blank
        assign sale_badge_text = 'content.product_badge_sale' | t
      endif
    endif

    assign sale_badge_tooltip_text = 'content.sale_badge_tooltip' | t
    if sale_badge_tooltip_text == blank or sale_badge_tooltip_text contains 'translation missing' or sale_badge_tooltip_text == 'content.sale_badge_tooltip'
      assign sale_badge_tooltip_text = 'If needed, this badge can link to any URL - 🚀🚀🚀'
    endif

    assign color_option = blank
    assign color_option_index = -1

    for option in product.options_with_values
      assign option_name = option.name | downcase
      if option_name contains 'color' or option_name contains 'colour' or option_name contains 'колір' or option_name contains 'цвет'
        assign color_option = option
        assign color_option_index = forloop.index0
        break
      endif
    endfor

    if color_option == blank
      for option in product.options_with_values
        assign swatch_count = option.values | map: 'swatch' | compact | size
        if swatch_count > 0
          assign color_option = option
          assign color_option_index = forloop.index0
          break
        endif
      endfor
    endif

    assign selected_color_value = ''
    case color_option_index
      when 0
        assign selected_color_value = selected_variant.option1
      when 1
        assign selected_color_value = selected_variant.option2
      when 2
        assign selected_color_value = selected_variant.option3
    endcase

    assign display_heading = product.title
    if product.metafields.custom.card_brand != blank
      assign display_heading = product.metafields.custom.card_brand.value
    endif

    assign display_title = product.title
    if product.metafields.custom.card_title != blank
      assign display_title = product.metafields.custom.card_title.value
    elsif product.metafields.custom.subtitle != blank
      assign display_title = product.metafields.custom.subtitle.value
    elsif product.type != blank
      assign display_title = product.type
    endif
  %}

  <article
    id="{{ card_id }}"
    class="assessment-product-card relative isolate z-0 mb-4 flex w-[calc(100%-6px)] min-w-0 max-w-[315px] flex-col items-start gap-[15px] p-0 text-[#111111] md:w-full"
    data-assessment-product-card
    data-product-id="{{ product.id }}"
    data-product-title="{{ image_alt_fallback | escape }}"
    data-selected-variant-id="{{ selected_variant.id }}"
    data-on-sale="{% if selected_on_sale %}true{% else %}false{% endif %}"
    data-manual-sale-badge="{% if manual_sale_badge %}true{% else %}false{% endif %}"
    data-sale-badge-mode="{{ sale_badge_mode }}"
    data-sale-badge-visible="{% if sale_badge_visible %}true{% else %}false{% endif %}"
  >
    <div class="assessment-image-panel relative box-border h-[270px] w-full overflow-hidden rounded-[10px] border bg-white md:h-[340px]">
      <div class="assessment-sale-badge-wrap absolute left-4 top-4 z-10 md:left-5 md:top-5" data-sale-badge-wrap>
        <button
          type="button"
          class="assessment-sale-badge relative box-border flex h-[27px] w-[84px] cursor-pointer items-center justify-center rounded-[24px] border px-[11px] py-[5px] text-center text-[15px] font-normal leading-[16px] md:h-[29.45px] md:w-[90.91px] md:rounded-[25.6098px] md:px-[13.8049px] md:py-[6.4024px] md:text-[16.5px] md:leading-[18px]"
          data-sale-badge
          data-sale-badge-trigger
          aria-expanded="false"
          aria-label="{{ sale_badge_text | escape }}"
        >
          {{ sale_badge_text }}
        </button>
        <span
          class="assessment-sale-badge-tooltip"
          data-sale-badge-tooltip
          role="status"
          aria-live="polite"
          aria-hidden="true"
        >
          {{ sale_badge_tooltip_text }}
        </span>
      </div>

      <a
        href="{{ selected_variant.url }}"
        class="assessment-media-frame relative z-0 block h-full w-full overflow-hidden rounded-[10px] focus-visible:outline-none"
        data-product-link
        aria-label="{{ product.title | escape }}"
      >
        {% if selected_primary != blank %}
          {% capture selected_primary_srcset -%}
            {{ selected_primary | image_url: width: 240 }} 240w,
            {{ selected_primary | image_url: width: 320 }} 320w,
            {{ selected_primary | image_url: width: 480 }} 480w,
            {{ selected_primary | image_url: width: 640 }} 640w,
            {{ selected_primary | image_url: width: 900 }} 900w
          {%- endcapture %}
          <img
            class="absolute inset-0 z-0 h-full w-full object-contain p-[8px]{% if selected_secondary != blank %} has-secondary{% endif %}"
            data-primary-image
            src="{{ selected_primary | image_url: width: 900 }}"
            srcset="{{ selected_primary_srcset | strip }}"
            sizes="{{ card_image_sizes }}"
            alt="{{ selected_primary.alt | default: image_alt_fallback | escape }}"
            width="{{ selected_primary.width }}"
            height="{{ selected_primary.height }}"
            loading="lazy"
            decoding="async"
          >
        {% else %}
          {{ 'product-apparel-1' | placeholder_svg_tag: 'absolute inset-0 h-full w-full object-contain p-[8px]' }}
        {% endif %}

        {% if secondary_fallback != blank %}
          {% capture secondary_fallback_srcset -%}
            {{ secondary_fallback | image_url: width: 240 }} 240w,
            {{ secondary_fallback | image_url: width: 320 }} 320w,
            {{ secondary_fallback | image_url: width: 480 }} 480w,
            {{ secondary_fallback | image_url: width: 640 }} 640w,
            {{ secondary_fallback | image_url: width: 900 }} 900w
          {%- endcapture %}
          <img
            class="absolute inset-0 z-0 h-full w-full object-contain p-[0px]{% if selected_secondary == blank %} hidden{% endif %}"
            data-secondary-image
            src="{{ secondary_fallback | image_url: width: 900 }}"
            srcset="{{ secondary_fallback_srcset | strip }}"
            sizes="{{ card_image_sizes }}"
            alt="{{ selected_secondary.alt | default: image_alt_fallback | escape }}"
            width="{{ secondary_fallback.width }}"
            height="{{ secondary_fallback.height }}"
            loading="lazy"
            decoding="async"
          >
        {% endif %}
      </a>
    </div>

    {% if color_option != blank %}
      <div
        class="flex w-full max-w-[246px] items-center p-0"
        role="group"
        aria-label="{{ color_option.name | escape }}"
        data-swatch-list
      >
        <div class="flex w-full flex-wrap items-start gap-2 p-0">
        {% assign swatch_option_key = 'option' | append: color_option.position %}
        {% for option_value in color_option.values %}
          {% liquid
            assign swatch_variant = blank
            for variant in product.variants
              if variant[swatch_option_key] == option_value.name
                if swatch_variant == blank
                  assign swatch_variant = variant
                endif
                if variant.id == selected_variant.id
                  assign swatch_variant = variant
                  break
                endif
              endif
            endfor

            if swatch_variant == blank
              assign swatch_variant = selected_variant
            endif

            assign swatch_background = '#9ca3af'
            if option_value.swatch and option_value.swatch.color
              assign swatch_background = 'rgb(' | append: option_value.swatch.color.rgb | append: ')'
            elsif option_value.swatch and option_value.swatch.image
              assign swatch_image_url = option_value.swatch.image | image_url: width: 64
              assign swatch_background = 'url(' | append: swatch_image_url | append: ')'
            else
              assign color_key = option_value.name | downcase | strip

              if color_key contains 'white'
                assign swatch_background = '#ffffff'
              elsif color_key contains 'black'
                assign swatch_background = '#111111'
              elsif color_key contains 'orange'
                assign swatch_background = '#ff6b35'
              elsif color_key contains 'green'
                assign swatch_background = '#0a7d11'
              elsif color_key contains 'blue'
                assign swatch_background = '#0d6da6'
              elsif color_key contains 'yellow'
                assign swatch_background = '#e9d36d'
              elsif color_key contains 'pink'
                assign swatch_background = '#e8b4ea'
              elsif color_key contains 'navy'
                assign swatch_background = '#1a2b65'
              elsif color_key contains 'purple'
                assign swatch_background = '#8049c9'
              elsif color_key contains 'red'
                assign swatch_background = '#ce2029'
              elsif color_key contains 'gray' or color_key contains 'grey'
                assign swatch_background = '#818b98'
              endif
            endif

            assign is_active = false
            if option_value.name == selected_color_value
              assign is_active = true
            endif
          %}

          <button
            type="button"
            class="assessment-swatch relative flex h-5 w-5 items-center justify-center rounded-full bg-transparent p-0 focus-visible:outline-none"
            aria-label="{{ option_value.name | escape }}"
            aria-pressed="{% if is_active %}true{% else %}false{% endif %}"
            data-swatch-button
            data-variant-id="{{ swatch_variant.id }}"
            data-active="{% if is_active %}true{% else %}false{% endif %}"
          >
            <span
              class="assessment-swatch-core block h-full w-full rounded-full"
              style="background: {{ swatch_background }}; background-size: cover; background-position: center; background-repeat: no-repeat;"
            ></span>
            <span class="assessment-swatch-tooltip" aria-hidden="true">{{ option_value.name }}</span>
          </button>
        {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="flex w-full max-w-[246px] min-w-0 flex-col items-start gap-[2px]">
      <div class="flex w-full max-w-[246px] min-w-0 flex-col items-start gap-[2px]">
        <p class="assessment-vendor-line m-0 w-full min-w-0 text-[14px] font-normal leading-[16px] text-[#111111] tracking-tight">
          {{ display_heading }}
        </p>
        <h3 class="my-1 w-full min-w-0 text-[16px]">
          <a
            href="{{ selected_variant.url }}"
            class="assessment-product-title assessment-product-title-wrap block w-full min-w-0 text-[16px] tracking-tight font-semibold leading-[18px] text-[#0A4874] no-underline hover:underline focus-visible:underline"
            data-product-link
          >
            {{ display_title }}
          </a>
        </h3>
      </div>

      <p class="assessment-price-row my-1 flex items-start gap-2">
        <span
          class="assessment-compare-price text-[14px] font-normal leading-[16px] text-[#111111] line-through"
          data-compare-price
        >
          {% if selected_on_sale %}{{ selected_variant.compare_at_price | money }}{% endif %}
        </span>
        <span
          class="assessment-current-price text-[14px] font-normal leading-[16px] text-[#111111]"
          data-current-price
        >
          {{ selected_variant.price | money }}
        </span>
      </p>
    </div>

    <script type="application/json" data-variant-json>
      {
        {% for variant in product.variants %}
          {% liquid
            assign variant_primary = variant.featured_media
            if variant_primary == blank or variant_primary.media_type != 'image'
              assign variant_primary = fallback_image
            endif

            assign variant_secondary = blank
            if product_images.size > 1 and variant_primary != blank
              for media in product_images
                if media.position > variant_primary.position
                  assign variant_secondary = media
                  break
                endif
              endfor
            endif
            if variant_secondary == blank and product_images.size > 1
              for media in product_images
                if variant_primary != blank and media.id == variant_primary.id
                  continue
                endif
                assign variant_secondary = media
                break
              endfor
            endif

            assign variant_is_on_sale = false
            if variant.compare_at_price > variant.price
              assign variant_is_on_sale = true
            endif

            assign variant_color_value = ''
            case color_option_index
              when 0
                assign variant_color_value = variant.option1
              when 1
                assign variant_color_value = variant.option2
              when 2
                assign variant_color_value = variant.option3
            endcase
          %}
          {% capture variant_primary_srcset -%}
            {{ variant_primary | image_url: width: 240 }} 240w,
            {{ variant_primary | image_url: width: 320 }} 320w,
            {{ variant_primary | image_url: width: 480 }} 480w,
            {{ variant_primary | image_url: width: 640 }} 640w,
            {{ variant_primary | image_url: width: 900 }} 900w
          {%- endcapture %}
          {% if variant_secondary %}
            {% capture variant_secondary_srcset -%}
              {{ variant_secondary | image_url: width: 240 }} 240w,
              {{ variant_secondary | image_url: width: 320 }} 320w,
              {{ variant_secondary | image_url: width: 480 }} 480w,
              {{ variant_secondary | image_url: width: 640 }} 640w,
              {{ variant_secondary | image_url: width: 900 }} 900w
            {%- endcapture %}
          {% else %}
            {% assign variant_secondary_srcset = '' %}
          {% endif %}
          "{{ variant.id }}": {
            "id": {{ variant.id | json }},
            "url": {{ variant.url | json }},
            "price": {{ variant.price | money | json }},
            "compareAtPrice": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}""{% endif %},
            "onSale": {{ variant_is_on_sale | json }},
            "primaryImage": {{ variant_primary | image_url: width: 900 | json }},
            "primarySrcset": {{ variant_primary_srcset | strip | json }},
            "primaryAlt": {{ variant_primary.alt | default: image_alt_fallback | json }},
            "secondaryImage": {% if variant_secondary %}{{ variant_secondary | image_url: width: 900 | json }}{% else %}null{% endif %},
            "secondarySrcset": {{ variant_secondary_srcset | strip | json }},
            "secondaryAlt": {{ variant_secondary.alt | default: image_alt_fallback | json }},
            "colorValue": {{ variant_color_value | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      }
    </script>
  </article>
{% endif %}
